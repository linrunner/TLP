$ sudo tlp setcharge 97 100 -- X_BAT_PLUGIN_SIMULATE=framework
Setting temporary charge threshold for BAT0:
  stop = 100
$ sudo tlp setcharge 0 66 -- X_BAT_PLUGIN_SIMULATE=framework
Setting temporary charge threshold for BAT0:
  stop =  66
$ sudo tlp setcharge 0 60 -- X_BAT_PLUGIN_SIMULATE=framework
Setting temporary charge threshold for BAT0:
  stop =  60
